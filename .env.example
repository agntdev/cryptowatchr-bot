BOT_TOKEN=
# Optional: CoinGecko Demo/Pro API key (reduces 429s on the free public IP pool).
# Demo keys use api.coingecko.com; set COINGECKO_API_MODE=pro for pro-api.coingecko.com.
COINGECKO_API_KEY=
COINGECKO_API_MODE=demo
# Owner Telegram user id for the usage dashboard button.
OWNER_TELEGRAM_ID=
# Optional Redis URL for durable domain data across restarts.
REDIS_URL=
